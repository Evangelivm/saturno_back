# Database
DATABASE_URL="mysql://user:password@localhost:3306/saturno_db"
DATABASE_URL_SECOND="mysql://user:password@localhost:3306/segunda_db"

# App
PORT=3001
NODE_ENV=development

# Better Auth
AUTH_SECRET=your-super-secret-key-change-this-in-production

# Google Drive
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./secrets/google-service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-folder-id

# SUNAT API (URLs oficiales)
SUNAT_TOKEN_URL=https://api-seguridad.sunat.gob.pe/v1/clientesextranet
SUNAT_API_BASE_URL=https://api.sunat.gob.pe/v1/contribuyente/contribuyentes

# CORS
CORS_ORIGIN=http://localhost:3000

# ── Elasticsearch ──────────────────────────────────────────────────────────────
# Nodo de ES (ver elasticsearch/docker-compose.yml)
ELASTICSEARCH_NODE=https://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme_elastic

# Para desarrollo con certificado autofirmado del docker-compose:
ELASTICSEARCH_TLS_VERIFY=false

# Para producción, reemplazar TLS_VERIFY=true y proveer el fingerprint del CA:
#   docker compose -f elasticsearch/docker-compose.yml exec elasticsearch \
#     bin/elasticsearch-certutil fingerprint --ca config/certs/ca/ca.crt --json \
#     | jq -r '.certificate_fingerprints[0]'
ELASTICSEARCH_CA_FINGERPRINT=
