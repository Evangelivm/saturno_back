# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo a .env y completa los valores
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Versión del stack (Elasticsearch + Kibana deben coincidir)
STACK_VERSION=8.13.4

# Nombre del cluster
CLUSTER_NAME=saturno-cluster

# Contraseña del usuario "elastic" (superusuario)
# Mínimo 6 caracteres, usa algo seguro en producción
ELASTIC_PASSWORD=changeme_elastic

# Contraseña del usuario interno "kibana_system"
KIBANA_PASSWORD=changeme_kibana

# Clave de cifrado de Kibana (mínimo 32 caracteres aleatorios)
# Puedes generar una con: openssl rand -hex 32
KIBANA_ENCRYPTION_KEY=reemplaza_con_32_caracteres_aleatorios_aqui

# Memoria JVM para Elasticsearch
# Regla: nunca superar el 50 % de la RAM disponible
# Ejemplos: 1g | 2g | 4g | 8g
ES_HEAP_SIZE=2g

# Puertos expuestos al host
ES_PORT=9200
KIBANA_PORT=5601

# Licencia: "basic" (gratuita) o "trial" (30 días platinum)
ES_LICENSE=basic

# ─────────────────────────────────────────────────────────────────────────────
# Variables que el backend NestJS necesita para conectarse
# Agrégalas también al .env principal del backend
# ─────────────────────────────────────────────────────────────────────────────
# ELASTICSEARCH_NODE=https://localhost:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme_elastic
# ELASTICSEARCH_CA_FINGERPRINT=   ← obtenido con el comando de abajo
